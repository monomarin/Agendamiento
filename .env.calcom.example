# 🐋 Cal.com Self-Hosted Environment variables
# Copia este archivo como .env.calcom para configurar tu instancia local de Cal.com

# URL base pública de tu panel de reservas de Cal.com (en local se usa el puerto 3001)
NEXT_PUBLIC_WEBAPP_URL=http://localhost:3001
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3001

# Clave secreta para NextAuth. Genera una con: openssl rand -base64 32
NEXTAUTH_SECRET=d8a3be095d3e0b2e8824f11559c5d0f5

# Clave de encriptación de 32 caracteres para datos sensibles en la BD.
# Genera una con: openssl rand -base64 24
CALENDSO_ENCRYPTION_KEY=6b815610d0f507b9e71ec26dcd8c7e0c

# Configuración de base de datos interna de Docker
POSTGRES_USER=unicorn_user
POSTGRES_PASSWORD=magical_password
POSTGRES_DB=calendso
DATABASE_URL=postgresql://unicorn_user:magical_password@database:5432/calendso

# Desactivar telemetría
CALCOM_TELEMETRY_DISABLED=1
